---
import { BodyLong, Heading, Loader } from "@navikt/ds-react";
import Breadcrumb from "@src/components/breadcrumb/Breadcrumb.astro";
import Utkast from "../../components/utkast/Utkast.astro";
import type { Language } from "../../language/language";
import { text } from "../../language/text";
import Layout from "../../layouts/Layout.astro";
import styles from "../../styles/index.module.css";

const language = Astro.currentLocale as Language;
---

<Layout title="Utkast">
  <div class={styles.headingWrapper}>
    <div>
      <Breadcrumb />
      <Heading size={'large'}>
        {text.utkast[language]}
      </Heading>
      <BodyLong className={styles.ingress} size={'large'}>
        {text.description[language]}
      </BodyLong>
    </div>
  </div>
  <div class={styles.utkastWrapper}>
    <Utkast language={language} server:defer>
      <Loader slot="fallback" />
    </Utkast>
  </div>
</Layout>
